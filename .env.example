# Скопіюйте файл у .env та підставте ваш токен бота
TELEGRAM_BOT_TOKEN=PASTE_YOUR_TOKEN_HERE
# Telegram user_id адміністраторів через кому (наприклад: 123456789,987654321)
ADMIN_USER_IDS=

# Опціонально: база даних (PostgreSQL/MySQL). Якщо порожньо — JSON файли в /data
# PostgreSQL: postgresql+psycopg2://user:password@localhost:5432/dyhi
# MySQL: mysql+pymysql://user:password@localhost:3306/dyhi?charset=utf8mb4
DATABASE_URL=

# Онлайн-оплата: liqpay або wayforpay
PAYMENT_PROVIDER=
LIQPAY_PUBLIC_KEY=
LIQPAY_PRIVATE_KEY=
LIQPAY_SERVER_URL=https://example.com/payment/success
WAYFORPAY_MERCHANT_ACCOUNT=
WAYFORPAY_SECRET_KEY=
WAYFORPAY_RETURN_URL=https://example.com/payment/success

# CRM webhook endpoint (опціонально)
CRM_WEBHOOK_URL=

# Nova Poshta API key (опціонально, для команди /np)
NOVA_POSHTA_API_KEY=
